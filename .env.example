# ─────────────────────────────────────────────────────────────
# AgenticZillow — environment variables
# Copy to .env and fill in. .env is git-ignored. Never commit secrets.
# ─────────────────────────────────────────────────────────────

# ── LLM providers (cost-ordered policy lives in code: Groq → DeepSeek/Gemini → OpenAI → Anthropic) ──
GROQ_API_KEY=
DEEPSEEK=                 # DeepSeek API key (note: legacy name, not DEEPSEEK_API_KEY)
GEMINI_API_KEY=           # Google AI Studio — used for vision + embeddings
OPENAI_API_KEY=
ANTHROPIC_API_KEY=        # premium fallback only

# ── Maps (optional — falls back to keyless MapLibre + OpenFreeMap if unset) ──
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Photos (optional — falls back to direct Unsplash CDN URLs if unset) ──
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=

# ── Supabase (optional now — app uses local JSON until these are set) ──
SUPABASE_ACCESS_TOKEN=                 # management token (CLI/Management API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=                          # pooled Postgres connection (pgvector enabled)

# ── App ──
APP_URL=http://localhost:3000
DEMO_USER_EMAIL=demo@agenticzillow.app
EMBEDDING_MODEL=gemini:text-embedding-004
EMBEDDING_DIM=768
LLM_ANTHROPIC_DAILY_USD_CAP=10
