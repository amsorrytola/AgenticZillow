{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/agentic/**",
              "components/buttons/**",
              "components/feedback/**",
              "components/forms/**",
              "components/property/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter))/i]",
        "message": "Font not provided by the design system. Available: Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='AgentTimelineRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:agent|label|status|time|model|cost|key|ref|className|style|children)$/]",
        "message": "<AgentTimelineRow> doesn't accept that prop. Declared props: agent, label, status, time, model, cost."
      },
      {
        "selector": "JSXOpeningElement[name.name='AgentTimelineRow'] > JSXAttribute[name.name='agent'] > Literal[value!=/^(?:orchestrator|search|market|finance|concierge)$/]",
        "message": "<AgentTimelineRow> agent must be one of 'orchestrator' | 'search' | 'market' | 'finance' | 'concierge'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AgentTimelineRow'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:running|ok|error)$/]",
        "message": "<AgentTimelineRow> status must be one of 'running' | 'ok' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AskPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|fab|badge|key|ref|className|style|children)$/]",
        "message": "<AskPill> doesn't accept that prop. Declared props: label, fab, badge."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|variant|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|blue|success|warning|error|violet)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'blue' | 'success' | 'warning' | 'error' | 'violet'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|soft|outline)$/]",
        "message": "<Badge> variant must be one of 'solid' | 'soft' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|pill|disabled|block|iconLeft|iconRight|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, pill, disabled, block, iconLeft, iconRight, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|text|destructive|agentic)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'text' | 'destructive' | 'agentic'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|label|disabled|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, label, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilterPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|applied|count|open|children|key|ref|className|style|children)$/]",
        "message": "<FilterPill> doesn't accept that prop. Declared props: label, applied, count, open, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|active|label|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: size, active, label, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:iconLeft|clearable|onClear|error|size|wrapStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: iconLeft, clearable, onClear, error, size, wrapStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<Input> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:price|state|key|ref|className|style|children)$/]",
        "message": "<PriceBubble> doesn't accept that prop. Declared props: price, state."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceBubble'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:default|viewed|saved|shortlisted)$/]",
        "message": "<PriceBubble> state must be one of 'default' | 'viewed' | 'saved' | 'shortlisted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PropertyCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:photo|status|statusLabel|price|beds|baths|sqft|homeType|address|saved|onSave|photoCount|priceCut|attribution|agentic|key|ref|className|style|children)$/]",
        "message": "<PropertyCard> doesn't accept that prop. Declared props: photo, status, statusLabel, price, beds, baths, sqft, homeType, address, saved, onSave, photoCount, priceCut, attribution, agentic."
      },
      {
        "selector": "JSXOpeningElement[name.name='PropertyCard'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:for-sale|for-rent|pending|contingent|coming-soon|new|sold|tour|open-house)$/]",
        "message": "<PropertyCard> status must be one of 'for-sale' | 'for-rent' | 'pending' | 'contingent' | 'coming-soon' | 'new' | 'sold' | 'tour' | 'open-house'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|label|key|ref|className|style|children)$/]",
        "message": "<StatusTag> doesn't accept that prop. Declared props: status, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusTag'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:for-sale|for-rent|pending|contingent|coming-soon|new|sold|tour|open-house)$/]",
        "message": "<StatusTag> status must be one of 'for-sale' | 'for-rent' | 'pending' | 'contingent' | 'coming-soon' | 'new' | 'sold' | 'tour' | 'open-house'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|action|onAction|children|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: tone, icon, action, onAction, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:success|error|info|neutral)$/]",
        "message": "<Toast> tone must be one of 'success' | 'error' | 'info' | 'neutral'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
